# Copy this file to .env for local development (never commit the real .env).
# On Vercel, set these as Project Settings -> Environment Variables instead.

# Required. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required. Any long random string — used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Required for production/Vercel. A Postgres connection string
# (postgres:// or postgresql://). Without this, the app falls back to a
# local SQLite file, which does NOT persist on Vercel's serverless
# filesystem — every cold start would look like a fresh, empty database.
# Leave empty for local development to use SQLite automatically.
DATABASE_URL=

# Optional but required for "forgot password" emails to actually be
# delivered. Without these, reset links are only logged server-side
# (see auth.py's _send_reset_email) -- the flow still works end to end
# for testing, it just doesn't reach a real inbox. Any standard SMTP
# relay works (Gmail app password, Resend, SendGrid SMTP, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Real JobSwiper listings (see jobs_data.py). Either or both can be
# set -- results are merged and deduped. JobSwiper strictly never shows
# fake/placeholder listings: with neither key set, or if both sources
# fail, Find Jobs shows its "check back later" empty state instead of
# any listings at all.
# Get a free key at https://jooble.org/api/about
JOOBLE_API_KEY=
# Get a free key by subscribing to JSearch at https://rapidapi.com/search?term=jsearch
RAPIDAPI_KEY=
